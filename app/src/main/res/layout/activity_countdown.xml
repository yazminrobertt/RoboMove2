<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/robomove_white">

    <!-- Title -->
    <TextView
        android:id="@+id/tv_get_ready"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GET READY....."
        android:textColor="@color/robomove_navy"
        android:textSize="62sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp"/>

    <!-- LEFT IMAGE -->

    <!-- RIGHT IMAGE -->

    <!-- CIRCLE CONTAINER -->

    <ImageView
        android:id="@+id/img_left"
        android:layout_width="412dp"
        android:layout_height="578dp"
        android:layout_marginStart="68dp"
        android:contentDescription="left image"
        android:src="@drawable/countdown_kid1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_get_ready"
        app:layout_constraintVertical_bias="1.0" />

    <ImageView
        android:id="@+id/img_right"
        android:layout_width="449dp"
        android:layout_height="1116dp"
        android:layout_marginEnd="48dp"
        android:contentDescription="right image"
        android:src="@drawable/countdown_kid2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_get_ready"
        app:layout_constraintVertical_bias="0.472" />

    <FrameLayout
        android:id="@+id/circle_container"
        android:layout_width="220dp"
        android:layout_height="220dp"
        app:layout_constraintTop_toBottomOf="@id/tv_get_ready"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.45">

        <!-- Circle background -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_countdown_circle"/>

        <!-- Countdown number -->
        <TextView
            android:id="@+id/tv_countdown_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3"
            android:textColor="@color/robomove_navy"
            android:textSize="96sp"
            android:textStyle="bold"
            android:layout_gravity="center"/>

    </FrameLayout>

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Get in position!"
        android:textColor="#888888"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@id/circle_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>