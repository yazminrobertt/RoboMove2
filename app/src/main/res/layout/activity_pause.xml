<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#BB000000">

    <androidx.cardview.widget.CardView
        android:id="@+id/pause_card"
        android:layout_width="500dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/robomove_white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="40dp">

            <!-- Pause icon -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏸"
                android:textSize="80sp"/>

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PAUSED"
                android:textColor="@color/robomove_navy"
                android:textSize="48sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

            <!-- Voice hint -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text='Say "Robomove Play" to resume'
                android:textColor="#888888"
                android:textSize="16sp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="32dp"/>

            <!-- RESUME button -->
            <TextView
                android:id="@+id/btn_resume"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="▶  Resume"
                android:textColor="@color/robomove_white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_button_yellow"
                android:layout_marginBottom="16dp"/>

            <!-- RESTART LEVEL button -->
            <TextView
                android:id="@+id/btn_restart_level"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="↺  Restart Level"
                android:textColor="@color/robomove_navy"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_rule_card"
                android:layout_marginBottom="16dp"/>

            <!-- END GAME button -->
            <TextView
                android:id="@+id/btn_end_game"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="✕  End Game"
                android:textColor="@color/robomove_white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_button_navy"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>