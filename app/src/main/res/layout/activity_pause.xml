<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/robomove_white">

    <!-- CENTER CARD -->
    <androidx.cardview.widget.CardView
        android:id="@+id/pause_card"
        android:layout_width="900dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="32dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/robomove_white"
        android:layout_margin="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="36dp">

            <!-- ICON -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏸"
                android:textSize="72sp"
                android:textColor="@color/robomove_navy"/>

            <!-- TITLE (MATCH HOME STYLE) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PAUSED"
                android:textColor="@color/robomove_navy"
                android:textSize="48sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginTop="8dp"/>

            <!-- SUBTEXT -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Say to resume the challenge"
                android:textColor="@color/robomove_navy"
                android:alpha="0.7"
                android:textSize="18sp"
                android:layout_marginTop="16dp"/>

            <!-- COMMAND BOX (styled like HOME button feel) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text='\"Robomove Play\"'
                android:textColor="@color/robomove_navy"
                android:textSize="26sp"
                android:textStyle="bold"
                android:background="@drawable/bg_rule_card"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:layout_marginTop="16dp"/>

            <!-- DIVIDER -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="20dp"/>

            <!-- BUTTON (MATCH HOME YELLOW STYLE) -->
            <TextView
                android:id="@+id/btn_go_home"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="GO TO HOME"
                android:textColor="@color/robomove_navy"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:backgroundTint="@color/robomove_yellow"
                android:background="@drawable/bg_button_yellow"/>
        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>