<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/robomove_white">

    <!-- ══ LEFT SIDE — Score + Message ══ -->

    <LinearLayout
        android:id="@+id/layout_left"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="60dp"
        android:paddingEnd="32dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/divider"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Congratulations title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Congratulations!"
            android:textColor="@color/robomove_navy"
            android:textSize="52sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"/>

        <!-- Motivational message — changes based on score -->
        <TextView
            android:id="@+id/tv_motivational_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You are a champion!"
            android:textColor="#666666"
            android:textSize="22sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="36dp"/>

        <!-- Score card -->
        <androidx.cardview.widget.CardView
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="@color/robomove_teal"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="28dp"
                android:paddingBottom="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Score"
                    android:textColor="#CCFFFFFF"
                    android:textSize="18sp"/>

                <TextView
                    android:id="@+id/tv_total_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/robomove_white"
                    android:textSize="80sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"/>

                <!-- Star rating row -->
                <TextView
                    android:id="@+id/tv_stars"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐⭐⭐"
                    android:textSize="32sp"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Per-level breakdown -->
        <TextView
            android:id="@+id/tv_score_breakdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#888888"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:lineSpacingMultiplier="1.5"/>

    </LinearLayout>

    <!-- Vertical divider -->
    <View
        android:id="@+id/divider"
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:background="#EEEEEE"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- ══ RIGHT SIDE — Buttons ══ -->

    <LinearLayout
        android:id="@+id/layout_right"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="32dp"
        android:paddingEnd="60dp"
        app:layout_constraintStart_toEndOf="@id/divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Trophy emoji — big and celebratory -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏆"
            android:textSize="96sp"
            android:layout_marginBottom="32dp"/>

        <!-- PLAY AGAIN button -->
        <TextView
            android:id="@+id/btn_play_again"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="▶  Play Again"
            android:textColor="@color/robomove_white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_button_yellow"
            android:layout_marginBottom="16dp"/>

        <!-- HOME button -->
        <TextView
            android:id="@+id/btn_home"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="⌂  Go to Home"
            android:textColor="@color/robomove_navy"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_rule_card"
            android:layout_marginBottom="16dp"/>

        <!-- Voice hint -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text='Say \"Robomove Start\" to play again'
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>