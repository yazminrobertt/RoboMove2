<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/robomove_white"
    android:fitsSystemWindows="true">

    <!-- ═════════ TOP BAR ═════════ -->

    <!-- Score -->
    <LinearLayout
        android:id="@+id/layout_score"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_score_card"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Score:"
            android:textColor="@color/robomove_white"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/robomove_white"
            android:textSize="38sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Exercise name + description stacked in centre top -->

    <!-- Reps -->

    <LinearLayout
        android:id="@+id/layout_exercise_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toStartOf="@id/layout_reps"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@id/layout_score"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Exercise title -->
        <TextView
            android:id="@+id/tv_exercise_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Raise your left hand"
            android:textColor="@color/robomove_navy"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Short written description — matches TTS instruction -->
        <TextView
            android:id="@+id/tv_exercise_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="Lift your left arm out to the side and up above your head!"
            android:textColor="#555555"
            android:textSize="13sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_reps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_score_card"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reps:"
            android:textColor="@color/robomove_white"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_reps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/5"
            android:textColor="@color/robomove_white"
            android:textSize="38sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- ═════════ MAIN CONTENT ═════════ -->

    <!-- Demo Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_demo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="28dp"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="@color/robomove_pink_bg"
        app:cardElevation="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/card_camera"
        app:layout_constraintTop_toBottomOf="@id/layout_score"
        app:layout_constraintBottom_toTopOf="@id/layout_progress"
        app:layout_constraintWidth_percent="0.48">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Demo Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Demo"
                android:textColor="@color/robomove_white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_gravity="top|start"
                android:layout_margin="16dp"/>

            <!-- Demo Video -->
            <TextureView
                android:id="@+id/video_demo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"/>

            <!-- Placeholder -->
            <TextView
                android:id="@+id/tv_demo_placeholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📹 Demo Video"
                android:textColor="@color/robomove_white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:visibility="visible"/>

        </FrameLayout>

    </androidx.cardview.widget.CardView>

    <!-- Camera Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_camera"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="28dp"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="@color/robomove_pink_bg"
        app:cardElevation="4dp"
        app:layout_constraintStart_toEndOf="@id/card_demo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_score"
        app:layout_constraintBottom_toTopOf="@id/layout_progress">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Camera Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kids Cam"
                android:textColor="@color/robomove_white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_gravity="top|start"
                android:layout_margin="16dp"/>

            <!-- Camera preview -->
            <androidx.camera.view.PreviewView
                android:id="@+id/camera_preview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <!-- Skeleton overlay — sits exactly on top of camera preview -->
            <com.robomove.app.vision.PoseOverlayView
                android:id="@+id/pose_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"/>

            <!-- Pause button (top right of camera card) -->
            <TextView
                android:id="@+id/btn_pause"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏸ Pause"
                android:textColor="@color/robomove_white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_navy"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_gravity="top|end"
                android:layout_margin="16dp"/>

        </FrameLayout>

    </androidx.cardview.widget.CardView>

    <!-- ═════════ BOTTOM PROGRESS ═════════ -->

    <androidx.cardview.widget.CardView
        android:id="@+id/layout_progress"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="@color/robomove_light_gray"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Progress Label -->
            <TextView
                android:id="@+id/tv_progress_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Exercise 1 of 4"
                android:textColor="@color/robomove_navy"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"/>

            <!-- Progress Bar Container -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <!-- Background Track -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="18dp"
                    android:background="@drawable/bg_progress_track"/>

                <!-- Progress Bar -->
                <ProgressBar
                    android:id="@+id/progress_bar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="18dp"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/progress_bar_drawable"/>

            </FrameLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>