<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/robomove_white">

    <!-- ═════════ TOP BAR ═════════ -->

    <!-- Score -->
    <LinearLayout
        android:id="@+id/layout_score"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/robomove_score_blue"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="14dp"
        android:paddingBottom="18dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Score:"
            android:textColor="@color/robomove_white"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/robomove_white"
            android:textSize="42sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Exercise Name -->
    <TextView
        android:id="@+id/tv_exercise_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Raise your left hand"
        android:textColor="@color/robomove_navy"
        android:textSize="50dp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="50dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/layout_score"
        app:layout_constraintEnd_toStartOf="@id/layout_reps"/>

    <!-- Reps -->
    <LinearLayout
        android:id="@+id/layout_reps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/robomove_score_blue"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="14dp"
        android:paddingBottom="18dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reps:"
            android:textColor="@color/robomove_white"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_reps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/5"
            android:textColor="@color/robomove_white"
            android:textSize="42sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- ═════════ MAIN CONTENT ═════════ -->

    <!-- Demo Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_demo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="@color/robomove_pink_bg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/card_camera"
        app:layout_constraintTop_toBottomOf="@id/layout_score"
        app:layout_constraintBottom_toTopOf="@id/layout_progress"
        app:layout_constraintWidth_percent="0.48">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Demo Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Demo"
                android:textColor="@color/robomove_white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_gravity="top|start"
                android:layout_margin="16dp"/>

            <!-- Demo Video -->
            <VideoView
                android:id="@+id/video_demo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"/>

            <!-- Placeholder -->
            <TextView
                android:id="@+id/tv_demo_placeholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📹 Demo Video"
                android:textColor="@color/robomove_white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:visibility="visible"/>

        </FrameLayout>

    </androidx.cardview.widget.CardView>

    <!-- Camera Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_camera"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="@color/robomove_pink_bg"
        app:layout_constraintStart_toEndOf="@id/card_demo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_score"
        app:layout_constraintBottom_toTopOf="@id/layout_progress">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Camera Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kids Cam"
                android:textColor="@color/robomove_white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_gravity="top|start"
                android:layout_margin="16dp"/>

            <!-- Camera Preview -->
            <androidx.camera.view.PreviewView
                android:id="@+id/camera_preview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <!-- Pause Button -->
            <TextView
                android:id="@+id/btn_pause"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏸ Pause"
                android:textColor="@color/robomove_white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_navy"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_gravity="top|end"
                android:layout_margin="16dp"/>

        </FrameLayout>

    </androidx.cardview.widget.CardView>

    <!-- ═════════ BOTTOM PROGRESS ═════════ -->

    <androidx.cardview.widget.CardView
        android:id="@+id/layout_progress"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="@color/robomove_light_gray"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- Progress Label -->
            <TextView
                android:id="@+id/tv_progress_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Exercise 1 of 4"
                android:textColor="@color/robomove_navy"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"/>

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_marginTop="10dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/robomove_progress_orange"
                android:progressBackgroundTint="#DDDDDD"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>