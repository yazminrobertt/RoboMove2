<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/robomove_white">

    <!-- CARD -->
    <androidx.cardview.widget.CardView
        android:layout_width="900dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="32dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="@color/robomove_white"
        android:layout_margin="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="36dp">

            <!-- ICON -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛑"
                android:textSize="64sp"
                android:textColor="@color/robomove_navy"/>

            <!-- TITLE (MATCH HOME STYLE) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="END GAME?"
                android:textColor="@color/robomove_navy"
                android:textSize="40sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginTop="12dp"/>

            <!-- SUBTEXT -->
            <TextView
                android:layout_width="350dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:alpha="0.7"
                android:gravity="center"
                android:lineSpacingMultiplier="1.3"
                android:text='Say \"Yes\" to go home\nor \"No\" to continue playing'
                android:textColor="@color/robomove_navy"
                android:textSize="18sp" />

            <!-- BUTTONS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="28dp">

                <!-- NO -->
                <TextView
                    android:id="@+id/btn_no"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:text="NO"
                    android:textColor="@color/robomove_navy"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_rule_card"
                    android:layout_marginEnd="12dp"/>

                <!-- YES -->
                <TextView
                    android:id="@+id/btn_yes"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:text="YES"
                    android:textColor="@color/robomove_navy"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_button_yellow"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>