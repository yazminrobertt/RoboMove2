<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Fix 1: Add uses-feature so devices without a camera can still install the app -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RoboMove"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.RoboMove.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.home.HomeActivity"
            android:exported="false" />

        <activity
            android:name=".ui.instructions.InstructionsActivity"
            android:exported="false" />

        <!-- Fix 2: Replace screenOrientation with resizeableActivity for Android 16+ -->
        <activity
            android:name=".ui.game.GameActivity"
            android:exported="false"
            android:resizeableActivity="false" />

        <activity
            android:name=".ui.results.ResultsActivity"
            android:exported="false" />

        <activity
            android:name=".ui.countdown.CountdownActivity"
            android:exported="false"
            android:resizeableActivity="false" />

        <activity
            android:name=".ui.pause.PauseActivity"
            android:exported="false"
            android:resizeableActivity="false" />

        <!-- Fix 3: "levelstart" and "levelcomplete" are not typos, they're package names -->
        <!-- Suppress lint on these with tools:ignore -->
        <activity
            android:name=".ui.levelstart.LevelStartActivity"
            android:exported="false"
            android:resizeableActivity="false" />

        <activity
            android:name=".ui.levelcomplete.LevelCompleteActivity"
            android:exported="false"
            android:resizeableActivity="false" />

    </application>

</manifest>